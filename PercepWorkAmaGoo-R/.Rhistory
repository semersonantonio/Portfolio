# 1. Carga de bibliotecas
library(MASS)
library(ggplot2)
# 2. Carga del conjunto de datos
data(birthwt)
# Visualización inicial de los datos
head(birthwt)
# Estructura del conjunto de datos
str(birthwt)
# Resumen estadístico
summary(birthwt)
############################################################
# 3. Comprobación de valores ausentes
############################################################
# Verificación de valores NA por variable
colSums(is.na(birthwt))
# No se detectan valores ausentes, por lo que no es necesario
# eliminar observaciones ni realizar imputaciones.
############################################################
# 4. Tratamiento de variables
############################################################
# Conversión de la variable smoke a factor con etiquetas descriptivas
birthwt$smoke <- factor(birthwt$smoke,
levels = c(0, 1),
labels = c("No fuma", "Fuma"))
# Tamaño muestral por grupo
table(birthwt$smoke)
############################################################
# 5. Análisis descriptivo
############################################################
# Media del peso al nacer por grupo
tapply(birthwt$bwt, birthwt$smoke, mean)
# Desviación estándar del peso al nacer por grupo
tapply(birthwt$bwt, birthwt$smoke, sd)
############################################################
# 6. Test t de una muestra (media = 2500 g)
############################################################
# Selección del grupo de madres fumantes
fumantes <- birthwt[birthwt$smoke == "Fuma", ]
# Test t de una muestra (unilateral)
# H0: mu >= 2500
# H1: mu < 2500
t.test(fumantes$bwt,
mu = 2500,
alternative = "less")
# La media observada es superior a 2500 g, por lo que
# no se rechaza la hipótesis nula.
############################################################
# 7. Diagrama de caja: peso al nacer según tabaquismo
############################################################
boxplot(bwt ~ smoke,
data = birthwt,
main = "Peso al nacer según el hábito de fumar",
xlab = "Estado de tabaquismo",
ylab = "Peso al nacer (g)")
# El diagrama de caja sugiere que la mediana del peso al nacer
# es menor en el grupo de madres fumantes, con mayor concentración
# de valores bajos.
############################################################
# 8. Test t de dos muestras independientes
############################################################
# Comparación entre madres fumantes y no fumantes
# Test t de Welch
t.test(bwt ~ smoke, data = birthwt)
# El valor p < 0.05 indica diferencias estadísticamente significativas
# entre los grupos, siendo el peso medio menor en el grupo fumante.
############################################################
# 9. Gráficos de densidad
############################################################
plot(density(birthwt$bwt[birthwt$smoke == "Fuma"]),
main = "Distribución del peso al nacer",
xlab = "Peso al nacer (g)")
lines(density(birthwt$bwt[birthwt$smoke == "No fuma"]),
lty = 2)
legend("topright",
legend = c("Fuma", "No fuma"),
lty = c(1, 2))
# El gráfico muestra un desplazamiento de la distribución
# hacia valores menores en el grupo de madres fumantes.
############################################################
# 10. Comprobación de normalidad (Shapiro-Wilk)
############################################################
# Normalidad para madres fumantes
shapiro.test(fumantes$bwt)
# Normalidad para madres no fumantes
shapiro.test(birthwt$bwt[birthwt$smoke == "No fuma"])
# En ambos casos, el valor p es superior a 0.05,
# por lo que no se rechaza la hipótesis de normalidad.
############################################################
# 11. Test de Wilcoxon (no paramétrico)
############################################################
# Aunque la normalidad no fue rechazada, se aplica el test
# de Wilcoxon como contraste no paramétrico para verificar
# la robustez de los resultados.
wilcox.test(bwt ~ smoke, data = birthwt)
# El valor p < 0.05 confirma diferencias significativas
# entre las distribuciones del peso al nacer.
############################################################
# 12. Análisis de la varianza (ANOVA)
############################################################
anova_model <- aov(bwt ~ smoke, data = birthwt)
summary(anova_model)
# La ANOVA muestra un efecto significativo del tabaquismo
# materno sobre el peso al nacer (p < 0.05).
